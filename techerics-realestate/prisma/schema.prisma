// ============================================================
// TECH ERICS REAL ESTATE PLATFORM — DATABASE SCHEMA
// Research-backed design: normalized geography hierarchy,
// versioned listings (price/status history), multi-language
// content tables, and SEO-ready fields on every entity.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------- GEOGRAPHY HIERARCHY ----------------
// Country -> Region/State -> City -> Locality
// Ye hierarchy footer ke "Popular Cities/Localities" links
// aur programmatic SEO pages (city/locality) dono ke liye use hogi.

model Country {
  id        String   @id @default(cuid())
  code      String   @unique // ISO 3166-1 alpha-2, e.g. "IN", "AE", "US"
  slug      String   @unique
  regions   Region[]
  createdAt DateTime @default(now())
}

model Region {
  id        String   @id @default(cuid())
  name      String
  slug      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]
  translations RegionTranslation[]

  @@unique([countryId, slug])
}

model City {
  id            String   @id @default(cuid())
  name          String
  slug          String
  regionId      String
  region        Region   @relation(fields: [regionId], references: [id])
  latitude      Float?
  longitude     Float?
  localities    Locality[]
  properties    Property[]
  seoContent    String?  @db.Text // AI-generated unique city overview (avoids duplicate content)
  translations  CityTranslation[]

  @@unique([regionId, slug])
  @@index([slug])
}

model Locality {
  id           String   @id @default(cuid())
  name         String
  slug         String
  cityId       String
  city         City     @relation(fields: [cityId], references: [id])
  latitude     Float?
  longitude    Float?
  avgPricePerSqft Float?
  properties   Property[]
  seoContent   String?  @db.Text
  translations LocalityTranslation[]

  @@unique([cityId, slug])
  @@index([slug])
}

// ---------------- TRANSLATIONS (multi-language SEO content) ----------------

model CityTranslation {
  id        String   @id @default(cuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  locale    String   // "en", "hi", "ar", ...
  name      String
  seoContent String? @db.Text
  metaTitle String?
  metaDescription String?

  @@unique([cityId, locale])
}

model LocalityTranslation {
  id         String   @id @default(cuid())
  localityId String
  locality   Locality @relation(fields: [localityId], references: [id])
  locale     String
  name       String
  seoContent String?  @db.Text
  metaTitle  String?
  metaDescription String?

  @@unique([localityId, locale])
}

model RegionTranslation {
  id       String @id @default(cuid())
  regionId String
  region   Region @relation(fields: [regionId], references: [id])
  locale   String
  name     String

  @@unique([regionId, locale])
}

// ---------------- CORE PROPERTY ENTITY ----------------
// "Property" = the physical asset (durable).
// "Listing" = the marketplace offer on that property (can change status/price over time).
// Ye split RealtyAPI/industry best-practice hai — history/versioning ke liye zaroori.

enum PropertyType {
  APARTMENT
  VILLA
  INDEPENDENT_HOUSE
  PLOT
  COMMERCIAL_OFFICE
  COMMERCIAL_SHOP
  WAREHOUSE
  PENTHOUSE
  STUDIO
}

enum ListingPurpose {
  SALE
  RENT
  PG
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
  OFF_MARKET
  EXPIRED
}

model Property {
  id            String       @id @default(cuid())
  slug          String       @unique // e.g. "3bhk-apartment-bandra-west-mumbai-xyz123"
  title         String
  description   String       @db.Text
  propertyType  PropertyType
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Float?
  lotSizeSqft   Float?
  yearBuilt     Int?
  floors        Int?

  // Geography
  cityId        String
  city          City         @relation(fields: [cityId], references: [id])
  localityId    String
  locality      Locality     @relation(fields: [localityId], references: [id])
  addressLine   String?
  latitude      Float
  longitude     Float

  // Relations
  agentId       String?
  agent         Agent?       @relation(fields: [agentId], references: [id])
  media         Media[]
  amenities     PropertyAmenity[]
  listings      Listing[]
  translations  PropertyTranslation[]
  leads         Lead[]

  // SEO fields — every property page auto-generates these
  metaTitle       String?
  metaDescription String?
  schemaJsonLd    String?  @db.Text // cached generated JSON-LD (regenerated on update)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([cityId, localityId])
  @@index([slug])
}

model PropertyTranslation {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  locale      String
  title       String
  description String   @db.Text
  metaTitle   String?
  metaDescription String?

  @@unique([propertyId, locale])
}

// Listing = versioned marketplace state (price/status history preserved, not overwritten)
model Listing {
  id           String        @id @default(cuid())
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id])
  purpose      ListingPurpose
  status       ListingStatus @default(ACTIVE)
  price        Decimal
  currency     String        @default("INR")
  priceHistory PriceHistory[]
  listedAt     DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, purpose])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  price     Decimal
  recordedAt DateTime @default(now())
}

// ---------------- MEDIA (photos, video, 360 tours, reels) ----------------

enum MediaType {
  PHOTO
  VIDEO
  TOUR_360
  REEL
  FLOOR_PLAN
}

model Media {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  type       MediaType
  url        String
  altText    String?   // auto-generated from property details for image SEO
  order      Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([propertyId, type])
}

// ---------------- AMENITIES ----------------

model Amenity {
  id         String              @id @default(cuid())
  name       String              @unique
  icon       String?
  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])

  @@id([propertyId, amenityId])
}

// ---------------- AGENTS / ORGANIZATION ----------------

model Agent {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  phone       String
  email       String?
  photoUrl    String?
  bio         String?    @db.Text
  properties  Property[]
  reviews     Review[]
  createdAt   DateTime   @default(now())
}

model Review {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  rating    Int      // 1-5
  comment   String?  @db.Text
  authorName String
  createdAt DateTime @default(now())
}

// ---------------- LEADS (dual capture: DB + WhatsApp) ----------------

enum LeadSource {
  WEBSITE_FORM
  WHATSAPP
  PHONE
  CHATBOT
}

model Lead {
  id          String     @id @default(cuid())
  propertyId  String?
  property    Property?  @relation(fields: [propertyId], references: [id])
  name        String
  phone       String
  email       String?
  message     String?    @db.Text
  source      LeadSource @default(WEBSITE_FORM)
  whatsappSent Boolean   @default(false)
  createdAt   DateTime   @default(now())

  @@index([createdAt])
}

// ---------------- ADMIN USERS ----------------

enum UserRole {
  SUPER_ADMIN
  EDITOR
  AGENT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      UserRole @default(EDITOR)
  createdAt DateTime @default(now())
}
