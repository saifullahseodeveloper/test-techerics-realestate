// ============================================================
// TECH ERICS REAL ESTATE PLATFORM — ENTERPRISE DATABASE SCHEMA
// Supports 6-level location hierarchy (Country -> State -> City ->
// Community -> SubCommunity -> Building), Developer profiles,
// RERA registration, Location Scores (WalkScore), and Multi-lingual SEO.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------- GEOGRAPHY HIERARCHY ----------------
// Country -> State -> City -> Community -> SubCommunity -> Building

model Country {
  id              String   @id @default(cuid())
  code            String   @unique // ISO 3166-1 alpha-2, e.g. "IN", "AE", "US", "GB", "SA"
  slug            String   @unique
  name            String
  nativeLanguage  String   @default("en")
  defaultCurrency String   @default("USD")
  currencySymbol  String   @default("$")
  flag            String   @default("🌐")
  regions         Region[]
  states          State[]
  developers      Developer[]
  properties      Property[]
  createdAt       DateTime @default(now())
}

model Region {
  id        String   @id @default(cuid())
  name      String
  slug      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]
  translations RegionTranslation[]

  @@unique([countryId, slug])
}

model State {
  id        String   @id @default(cuid())
  name      String
  slug      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]

  @@unique([countryId, slug])
}

model City {
  id            String   @id @default(cuid())
  name          String
  slug          String
  regionId      String?
  region        Region?  @relation(fields: [regionId], references: [id])
  stateId       String?
  state         State?   @relation(fields: [stateId], references: [id])
  latitude      Float?
  longitude     Float?
  localities    Locality[]
  communities   Community[]
  properties    Property[]
  seoContent    String?  @db.Text
  translations  CityTranslation[]

  @@unique([slug])
  @@index([slug])
}

model Locality {
  id              String   @id @default(cuid())
  name            String
  slug            String
  cityId          String
  city            City     @relation(fields: [cityId], references: [id])
  latitude        Float?
  longitude       Float?
  avgPricePerSqft Float?
  properties      Property[]
  seoContent      String?  @db.Text
  translations    LocalityTranslation[]

  @@unique([cityId, slug])
  @@index([slug])
}

model Community {
  id              String   @id @default(cuid())
  name            String
  slug            String
  cityId          String
  city            City     @relation(fields: [cityId], references: [id])
  latitude        Float?
  longitude       Float?
  avgPricePerSqft Float?
  subCommunities  SubCommunity[]
  buildings       Building[]
  properties      Property[]

  @@unique([cityId, slug])
  @@index([slug])
}

model SubCommunity {
  id          String   @id @default(cuid())
  name        String
  slug        String
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  latitude    Float?
  longitude   Float?
  buildings   Building[]
  properties  Property[]

  @@unique([communityId, slug])
}

model Building {
  id             String   @id @default(cuid())
  name           String
  slug           String
  communityId    String?
  community      Community? @relation(fields: [communityId], references: [id])
  subCommunityId String?
  subCommunity   SubCommunity? @relation(fields: [subCommunityId], references: [id])
  developerId    String?
  developer      Developer? @relation(fields: [developerId], references: [id])
  floors         Int?
  yearBuilt      Int?
  properties     Property[]

  @@unique([slug])
}

model Developer {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  countryCode String   @default("AE")
  countryId   String?
  country     Country? @relation(fields: [countryId], references: [id])
  reraNumber  String?
  logoUrl     String?
  bio         String?  @db.Text
  projectCount Int     @default(0)
  buildings   Building[]
  properties  Property[]
  createdAt   DateTime @default(now())
}

// ---------------- TRANSLATIONS (multi-language SEO content) ----------------

model CityTranslation {
  id              String   @id @default(cuid())
  cityId          String
  city            City     @relation(fields: [cityId], references: [id])
  locale          String
  name            String
  seoContent      String?  @db.Text
  metaTitle       String?
  metaDescription String?

  @@unique([cityId, locale])
}

model LocalityTranslation {
  id              String   @id @default(cuid())
  localityId      String
  locality        Locality @relation(fields: [localityId], references: [id])
  locale          String
  name            String
  seoContent      String?  @db.Text
  metaTitle       String?
  metaDescription String?

  @@unique([localityId, locale])
}

model RegionTranslation {
  id       String @id @default(cuid())
  regionId String
  region   Region @relation(fields: [regionId], references: [id])
  locale   String
  name     String

  @@unique([regionId, locale])
}

// ---------------- CORE PROPERTY ENTITY ----------------

enum PropertyType {
  APARTMENT
  VILLA
  TOWNHOUSE
  INDEPENDENT_HOUSE
  PLOT
  COMMERCIAL_OFFICE
  COMMERCIAL_SHOP
  WAREHOUSE
  PENTHOUSE
  STUDIO
}

enum ListingPurpose {
  SALE
  RENT
  PG
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
  OFF_MARKET
  EXPIRED
}

enum CompletionStatus {
  READY
  OFF_PLAN
  UNDER_CONSTRUCTION
}

enum FurnishedStatus {
  FURNISHED
  UNFURNISHED
  SEMI_FURNISHED
}

model Property {
  id            String           @id @default(cuid())
  slug          String           @unique
  title         String
  description   String           @db.Text
  propertyType  PropertyType
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Float?
  lotSizeSqft   Float?
  yearBuilt     Int?
  floors        Int?

  completionStatus CompletionStatus @default(READY)
  furnishedStatus  FurnishedStatus  @default(UNFURNISHED)
  reraPermitNo     String?
  walkScore        Int?             @default(85)
  transitScore     Int?             @default(80)
  schoolScore      Int?             @default(90)

  // Geography
  countryId      String?
  country        Country?         @relation(fields: [countryId], references: [id])
  cityId         String
  city           City             @relation(fields: [cityId], references: [id])
  localityId     String
  locality       Locality         @relation(fields: [localityId], references: [id])
  communityId    String?
  community      Community?       @relation(fields: [communityId], references: [id])
  subCommunityId String?
  subCommunity   SubCommunity?    @relation(fields: [subCommunityId], references: [id])
  buildingId     String?
  building       Building?        @relation(fields: [buildingId], references: [id])
  developerId    String?
  developer      Developer?       @relation(fields: [developerId], references: [id])
  addressLine    String?
  latitude       Float
  longitude      Float

  // Relations
  agentId       String?
  agent         Agent?           @relation(fields: [agentId], references: [id])
  media         Media[]
  amenities     PropertyAmenity[]
  listings      Listing[]
  translations  PropertyTranslation[]
  leads         Lead[]
  savedProperties SavedProperty[]

  // SEO fields
  metaTitle       String?
  metaDescription String?
  schemaJsonLd    String?        @db.Text

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([cityId, localityId])
  @@index([slug])
}

model PropertyTranslation {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  locale      String
  title       String
  description String   @db.Text
  metaTitle   String?
  metaDescription String?

  @@unique([propertyId, locale])
}

model Listing {
  id           String        @id @default(cuid())
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id])
  purpose      ListingPurpose
  status       ListingStatus @default(ACTIVE)
  price        Decimal
  currency     String        @default("INR")
  priceHistory PriceHistory[]
  listedAt     DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status, purpose])
}

model PriceHistory {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  price      Decimal
  recordedAt DateTime @default(now())
}

// ---------------- MEDIA ----------------

enum MediaType {
  PHOTO
  VIDEO
  TOUR_360
  REEL
  FLOOR_PLAN
}

model Media {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id])
  type       MediaType
  url        String
  altText    String?
  order      Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([propertyId, type])
}

// ---------------- AMENITIES ----------------

model Amenity {
  id         String            @id @default(cuid())
  name       String            @unique
  icon       String?
  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])

  @@id([propertyId, amenityId])
}

// ---------------- AGENTS / ORGANIZATION ----------------

model Agent {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  phone       String
  email       String?
  photoUrl    String?
  bio         String?    @db.Text
  properties  Property[]
  reviews     Review[]
  createdAt   DateTime   @default(now())
}

model Review {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  rating     Int
  comment    String?  @db.Text
  authorName String
  createdAt  DateTime @default(now())
}

// ---------------- LEADS ----------------

enum LeadSource {
  WEBSITE_FORM
  WHATSAPP
  PHONE
  CHATBOT
}

model Lead {
  id           String     @id @default(cuid())
  propertyId   String?
  property     Property?  @relation(fields: [propertyId], references: [id])
  name         String
  phone        String
  email        String?
  message      String?    @db.Text
  source       LeadSource @default(WEBSITE_FORM)
  whatsappSent Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([createdAt])
}

// ---------------- ADMIN USERS ----------------

enum UserRole {
  SUPER_ADMIN
  EDITOR
  AGENT
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(USER)
  savedProperties SavedProperty[]
  createdAt DateTime @default(now())
}

// ---------------- USER SAVED PROPERTIES ----------------

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

// ---------------- BLOGS & AREA GUIDES ----------------

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  posts       BlogPost[]
  createdAt   DateTime   @default(now())
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String       @db.Text
  coverImage  String?
  authorName  String
  readTime    Int          @default(5)
  published   Boolean      @default(false)
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  translations BlogPostTranslation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BlogPostTranslation {
  id          String   @id @default(cuid())
  postId      String
  post        BlogPost @relation(fields: [postId], references: [id])
  locale      String
  title       String
  content     String   @db.Text

  @@unique([postId, locale])
}
