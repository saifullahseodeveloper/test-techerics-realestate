# ============================================================
# Copy this to .env.local (development) and set the same keys
# in Vercel Project Settings -> Environment Variables (production)
# NEVER commit the real .env.local file to git.
# ============================================================

# --- Database (Neon) ---
# DATABASE_URL = pooled connection, used by the app at runtime
# DIRECT_URL   = unpooled connection, used by Prisma Migrate
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/techerics?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/techerics?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-byte-string"
AUTH_TRUST_HOST="true"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://techerics.com"

# --- Google Gemini API (auto-SEO content generation — free tier) ---
GEMINI_API_KEY="paste-your-gemini-api-key-here"

# --- Cloudinary (media storage — free plan, NO credit card required) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="techerics-unsigned"

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-permanent-access-token"

# --- Seed script (first admin login — change immediately after first login) ---
SEED_ADMIN_EMAIL="admin@techerics.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# --- Search engine verification (Search Console / Bing Webmaster) ---
NEXT_PUBLIC_GSC_VERIFICATION="paste-google-search-console-verification-code"
NEXT_PUBLIC_BING_VERIFICATION="paste-bing-webmaster-verification-code"

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# --- Maps (optional — falls back to a keyless embed if not set) ---
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY="your-google-maps-embed-api-key"

# --- Instagram Graph API (auto-post reels/photos on new property) ---
INSTAGRAM_BUSINESS_ACCOUNT_ID="your-ig-business-account-id"
INSTAGRAM_ACCESS_TOKEN="your-long-lived-page-access-token"
